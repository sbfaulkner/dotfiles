#!/usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

file="${1:-}"
[ -n "$file" ] && [ -f "$file" ] || exit 1

get_columns(){
  local cols
  cols="${COLUMNS:-$(tput cols 2>/dev/null || true)}"
  printf '%s' "${cols:-100}"
}

detect_theme(){
  if defaults read -g AppleInterfaceStyle >/dev/null 2>&1; then
    printf 'dark'
  else
    printf 'light'
  fi
}

format_for_extension(){
  case "$1" in
    *.md|*.markdown|*.mdown|*.mkd)
      printf 'markdown'
      ;;
    *.json)
      printf 'json'
      ;;
    *.yaml|*.yml)
      printf 'yaml'
      ;;
  esac
}

format_for_mime_type(){
  local mime
  if command -v file >/dev/null 2>&1; then
    mime="$(file --mime-type -b -- "$file" 2>/dev/null || true)"
    mime="$(printf '%s' "$mime" | tr '[:upper:]' '[:lower:]')"
  else
    mime=""
  fi

  case "$mime" in
    application/json|text/json|application/x-json|*+json)
      echo "json"
      ;;
    text/markdown|text/x-markdown)
      echo "markdown"
      ;;
    application/x-yaml|text/yaml|text/x-yaml)
      echo "yaml"
      ;;
  esac
}

format="$(format_for_extension "$file")"
format="${format:-$(format_for_mime_type "$file")}"

case "$format" in
  markdown)
    glow --version >/dev/null 2>&1 || exit 1
    exec glow --style "$(detect_theme)" --width "$(get_columns)" "$file"
    ;;
  json)
    jq --version >/dev/null 2>&1 || exit 1
    exec jq -C . "$file"
    ;;
  yaml)
    yq --version >/dev/null 2>&1 || exit 1
    exec yq -C -P eval '.' "$file"
    ;;
  *)
    exit 1
    ;;
esac
