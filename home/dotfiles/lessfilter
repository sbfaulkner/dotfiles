#!/usr/bin/env bash
set -o errexit
set -o nounset
set -o pipefail

file="${1:-}"
[ -n "$file" ] && [ -f "$file" ] || exit 1

# determine columns: prefer $COLUMNS, fall back to tput cols, then 100
cols="${COLUMNS:-}"
if [ -z "$cols" ]; then
  cols=$(tput cols 2>/dev/null || true)
fi
width="${cols:-100}"

detect_theme(){
  if defaults read -g AppleInterfaceStyle >/dev/null 2>&1; then
    printf 'dark'
  else
    printf 'light'
  fi
}

case "$file" in
  *.md|*.markdown|*.mdown|*.mkd)
    glow --version >/dev/null 2>&1 || exit 1
    exec glow --style "$(detect_theme)" --width "$width" "$file"
    ;;
  *.json)
    jq --version >/dev/null 2>&1 || exit 1
    exec jq -C . "$file"
    ;;
  *.yaml|*.yml)
    yq --version >/dev/null 2>&1 || exit 1
    exec yq -C -P eval '.' "$file"
    ;;
  *)
    exit 1
    ;;
esac
