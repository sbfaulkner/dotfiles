# secrets functions sourced by home/shell.nix
# Location: ${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles/functions/secrets

# Helper: return the full path to the secrets ejson file for an optional name
# Simplified: assume the caller provides a name without an extension and always
# append .ejson. Example: default -> ${XDG_CONFIG_HOME:-$HOME/.config}/secrets/default.ejson
_secretspath() {
  local dir="${XDG_CONFIG_HOME:-$HOME/.config}/secrets"
  local name="${1:-default}"

  printf '%s/%s.ejson' "$dir" "$name"
}

# Internal editor + re-encrypt helper
# Note: do NOT decrypt before editing. We copy and edit the encrypted .ejson
# file directly. After editing we run `ejson encrypt` which will encrypt only
# newly added plaintext values and leave existing encrypted values alone.
_secretsedit() {
  local EJSON="$(_secretspath "$1")"

  [ -f "$EJSON" ] || { echo "Secrets file not found: $EJSON" >&2; return 1; }

  local orig tmp
  orig="$(mktemp "${TMPDIR:-/tmp}/secrets.orig.XXXXXX")" || return 1
  tmp="$(mktemp "${TMPDIR:-/tmp}/secrets.edit.XXXXXX")" || { rm -f "$orig"; return 1; }
  trap 'rm -f "$orig" "$tmp"' EXIT

  # Copy the encrypted source to the edit buffer — do not decrypt
  cp "$EJSON" "$orig"
  cp "$orig" "$tmp"

  ${EDITOR:-vi} "$tmp"

  cmp -s "$orig" "$tmp" && { echo "No changes made to $EJSON"; return 0; }

  # ejson encrypt will encrypt any plaintext values in the edited file and
  # leave existing encrypted values untouched.
  if ! ejson encrypt "$tmp" >/dev/null 2>&1; then
    echo "Failed to encrypt edited secrets" >&2
    return 1
  fi

  mv "$tmp" "$EJSON"
  echo "Re-encrypted secrets: $EJSON"
  rm -f "$orig"
}

# Public helper: either edit or load into env
secrets() {
  if [ "$1" = "-e" ] || [ "$1" = "--edit" ]; then
    shift
    _secretsedit "$1"
    return $?
  fi

  local EJSON="$(_secretspath "$1")"

  if [ -f "$EJSON" ]; then
    echo "Loading secrets: $EJSON"
    eval "$(ejson2env "$EJSON")"
  else
    echo "Secrets file not found: $EJSON"
    return 1
  fi
}
