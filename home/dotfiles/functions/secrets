# secrets functions sourced by home/shell.nix
# Location: ${XDG_CONFIG_HOME:-$HOME/.config}/dotfiles/functions/secrets

# Helper: return the full path to the secrets ejson file for an optional name
# Simplified: assume the caller provides a name without an extension and always
# append .ejson. Example: default -> ${XDG_CONFIG_HOME:-$HOME/.config}/secrets/default.ejson
_secretspath() {
  local dir="${XDG_CONFIG_HOME:-$HOME/.config}/secrets"
  local name="${1:-default}"

  printf '%s/%s.ejson' "$dir" "$name"
}

# Helper to compute a checksum for a file (prints hash or empty on failure).
_file_checksum() {
  local file="$1"
  if command -v shasum >/dev/null 2>&1; then
    shasum -a 256 "$file" | cut -d' ' -f1
  elif command -v sha256sum >/dev/null 2>&1; then
    sha256sum "$file" | cut -d' ' -f1
  elif command -v md5sum >/dev/null 2>&1; then
    md5sum "$file" | cut -d' ' -f1
  elif command -v md5 >/dev/null 2>&1; then
    md5 -q "$file"
  else
    printf ''
  fi
}

# Internal editor + re-encrypt helper
# Note: do NOT decrypt before editing. We copy and edit the encrypted .ejson
# file directly. After editing we run `ejson encrypt` which will encrypt only
# newly added plaintext values and leave existing encrypted values alone.
_secretsedit() {
  local EJSON="$(_secretspath "$1")"

  [ -f "$EJSON" ] || { echo "Secrets file not found: $EJSON" >&2; return 1; }
  command -v ejson >/dev/null 2>&1 || { echo "ejson is not installed or not on PATH" >&2; return 1; }

  local tmp origsum newsum rc=0
  tmp="$(mktemp "${TMPDIR:-/tmp}/secrets.edit.XXXXXX")" || return 1

  # Copy encrypted source to the edit buffer (work on temp only)
  if ! cp "$EJSON" "$tmp"; then rm -f "$tmp"; return 1; fi

  origsum="$(_file_checksum "$EJSON")"

  ${EDITOR:-vi} "$tmp"

  # If we have a checksum utility use it; otherwise fall back to cmp -s
  if [ -n "$origsum" ]; then
    newsum="$(_file_checksum "$tmp")"
    if [ "$origsum" = "$newsum" ]; then
      rm -f "$tmp"
      return 0
    fi
  else
    if cmp -s "$EJSON" "$tmp"; then
      rm -f "$tmp"
      return 0
    fi
  fi

  # Encrypt only the edited file; ejson encrypt leaves existing encrypted
  # values as-is and only encrypts newly provided plaintext strings.
  if ! ejson encrypt "$tmp" >/dev/null 2>&1; then
    echo "Failed to encrypt edited secrets" >&2
    rm -f "$tmp"
    return 1
  fi

  if ! mv "$tmp" "$EJSON"; then
    echo "Failed to replace original secrets file" >&2
    rm -f "$tmp"
    return 1
  fi

  echo "Re-encrypted secrets: $EJSON"
  return $rc
}

# Public helper: either edit or load into env
secrets() {
  if [ "$1" = "-e" ] || [ "$1" = "--edit" ]; then
    shift
    _secretsedit "$1"
    return $?
  fi

  local EJSON="$(_secretspath "$1")"

  if [ -f "$EJSON" ]; then
    echo "Loading secrets: $EJSON"
    eval "$(ejson2env "$EJSON")"
  else
    echo "Secrets file not found: $EJSON"
    return 1
  fi
}
