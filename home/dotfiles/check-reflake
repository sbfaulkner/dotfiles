#!/usr/bin/env bash
set -euo pipefail

# Minimal check-reflake script (deployed to $XDG_CONFIG_HOME/dotfiles/check-reflake)
# - Detects remote changes via git ls-remote
# - Detects local changes vs last successful reflake (LAST_HEAD in state file)
# - Supports two timeframes:
#   * CHECK_AGE_DAYS (default 1): if we haven't checked recently, run the
#     lightweight check (remote/local detection).
#   * PROMPT_AGE_DAYS (default 7): if it's been this long since the last
#     successful reflake, skip the lightweight check and prompt the user
#     directly to run reflake.
# - Modes: prompt (default), auto, auto-pull, disabled

DOTFILES="${DOTFILES:-$HOME/src/github.com/sbfaulkner/dotfiles}"
STATE_DIR="${REFLAKE_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/dotfiles}"
STATE_FILE="$STATE_DIR/reflake-last"
LOCK_DIR="$STATE_DIR/reflake-lock"
MODE="${REFLAKE_MODE:-prompt}"
# Backwards-compatible env var: REFLAKE_AGE_DAYS (used historically) is treated
# as the check age if provided. New variables:
CHECK_AGE_DAYS="${REFLAKE_CHECK_AGE_DAYS:-${REFLAKE_AGE_DAYS:-1}}"
PROMPT_AGE_DAYS="${REFLAKE_PROMPT_AGE_DAYS:-7}"

usage(){
  cat <<EOF
Usage: $(basename "$0") [--force] [--yes] [--preview] [--check-age DAYS] [--prompt-age DAYS]
  --force       ignore timestamp/age gating
  --yes         run without prompting
  --preview     run non-activating build instead of switch
  --check-age   override default check age (days)
  --prompt-age  override prompt age (days)
EOF
  exit 2
}

FORCE=0
YES=0
PREVIEW=0
while [[ $# -gt 0 ]]; do
  case "$1" in
    --force) FORCE=1; shift ;;
    --yes) YES=1; shift ;;
    --preview) PREVIEW=1; shift ;;
    --check-age) CHECK_AGE_DAYS="$2"; shift 2 ;;
    --prompt-age) PROMPT_AGE_DAYS="$2"; shift 2 ;;
    -h|--help) usage ;;
    *) echo "Unknown arg: $1"; usage ;;
  esac
done

mkdir -p "$STATE_DIR"

lock(){
  if mkdir "$LOCK_DIR" 2>/dev/null; then
    return 0
  else
    # already locked
    return 1
  fi
}

unlock(){
  rm -rf "$LOCK_DIR" || true
}

# Acquire lock to avoid concurrent prompts/runs. If lock cannot be obtained,
# another session is already running the check; exit quietly.
if ! lock; then
  exit 0
fi

trap "unlock" EXIT INT TERM

# simple tty check
is_tty(){ [[ -t 1 ]] ; }

# read recorded head and epochs from state file
recorded_head=""
last_check_epoch=0     # last time we performed a check
last_success_epoch=0   # last time a reflake ran successfully
if [[ -f "$STATE_FILE" ]]; then
  recorded_head=$(sed -n 's/^LAST_HEAD=//p' "$STATE_FILE" || true)
  last_check_epoch=$(sed -n 's/^LAST_CHECK_EPOCH=//p' "$STATE_FILE" || echo 0)
  last_success_epoch=$(sed -n 's/^LAST_SUCCESS_EPOCH=//p' "$STATE_FILE" || echo 0)
fi

# determine local head and branch
if [[ -d "$DOTFILES/.git" ]]; then
  branch=$(git -C "$DOTFILES" rev-parse --abbrev-ref HEAD 2>/dev/null || true)
  local_head=$(git -C "$DOTFILES" rev-parse HEAD 2>/dev/null || true)
else
  echo "Dotfiles path $DOTFILES is not a git checkout." >&2
  exit 2
fi

# detect dirty working tree (unstaged or staged changes)
repo_dirty=0
if ! git -C "$DOTFILES" diff --quiet --ignore-submodules -- || ! git -C "$DOTFILES" diff --cached --quiet; then
  repo_dirty=1
fi

now_epoch=$(date +%s)

# If a recent successful reflake hasn't run in PROMPT_AGE_DAYS, prefer to ask the
# user directly (skip a network check). This avoids noisy network calls for
# long-stale setups and surfaces the prompt to reflake sooner.
prompt_age_seconds=$(( PROMPT_AGE_DAYS * 86400 ))
if [[ $FORCE -eq 0 && $last_success_epoch -ne 0 && $(( now_epoch - last_success_epoch )) -ge $prompt_age_seconds ]]; then
  # If non-interactive, record last check time and exit quietly
  if ! is_tty && [[ $YES -eq 0 ]]; then
    printf "LAST_CHECK_EPOCH=%s\nLAST_HEAD=%s\nLAST_SUCCESS_EPOCH=%s\n" "$now_epoch" "$local_head" "$last_success_epoch" > "$STATE_FILE"
    exit 0
  fi

  # interactive: prompt user to run reflake now (skip remote check)
  if ! is_tty && [[ $YES -eq 1 ]]; then
    ans="y"
  else
    printf "It\'s been %d days since the last successful reflake. Run reflake now? [y/N] " $(( (now_epoch - last_success_epoch) / 86400 ))
    read -r ans || ans="n"
  fi
  if [[ "$ans" =~ ^[Yy]$ ]]; then
    if repo_dirty; then
      echo "Repo dirty; please stash/commit before running reflake." >&2
      exit 3
    fi

    run_reflake(){
      echo "Running reflake..."
      if command -v reflake >/dev/null 2>&1; then
        reflake
        return $?
      elif command -v home-manager >/dev/null 2>&1; then
        home-manager switch --flake "$DOTFILES#work"
        return $?
      elif command -v darwin-rebuild >/dev/null 2>&1; then
        sudo darwin-rebuild switch --flake "$DOTFILES#sbfaulkner"
        return $?
      else
        echo "No reflake command found; please ensure 'reflake' alias or home-manager/darwin-rebuild is available." >&2
        return 2
      fi
    }

    run_reflake || exit $?
    now_epoch=$(date +%s)
    printf "LAST_CHECK_EPOCH=%s\nLAST_HEAD=%s\nLAST_SUCCESS_EPOCH=%s\n" "$now_epoch" "$local_head" "$now_epoch" > "$STATE_FILE"
    exit 0
  else
    echo "Skipped."; printf "LAST_CHECK_EPOCH=%s\nLAST_HEAD=%s\nLAST_SUCCESS_EPOCH=%s\n" "$now_epoch" "$local_head" "$last_success_epoch" > "$STATE_FILE"; exit 0
  fi
fi

# CHECK gating: only perform the lightweight check if it's been at least
# CHECK_AGE_DAYS since the last check.
check_age_seconds=$(( CHECK_AGE_DAYS * 86400 ))
if [[ $FORCE -eq 0 && $last_check_epoch -ne 0 && $(( now_epoch - last_check_epoch )) -lt $check_age_seconds ]]; then
  # nothing to do and not old enough
  exit 0
fi

# fast remote check via ls-remote
remote_head=""
if [[ -n "$branch" ]]; then
  remote_head=$(git -C "$DOTFILES" ls-remote origin "refs/heads/$branch" 2>/dev/null | cut -f1 || true)
fi

remote_changed=0
local_changed=0

if [[ -n "$remote_head" && "$remote_head" != "$local_head" ]]; then
  remote_changed=1
elif [[ $repo_dirty -eq 1 ]]; then
  # Uncommitted changes count as a local change that should prompt the user
  local_changed=1
elif [[ -n "$recorded_head" && "$local_head" != "$recorded_head" ]]; then
  local_changed=1
fi

# If non-interactive and not --yes, record last check and exit (avoid background prompts)
if ! is_tty && [[ $YES -eq 0 ]]; then
  printf "LAST_CHECK_EPOCH=%s\nLAST_HEAD=%s\nLAST_SUCCESS_EPOCH=%s\n" "$now_epoch" "$local_head" "$last_success_epoch" > "$STATE_FILE"
  exit 0
fi

# run preview helper
run_preview(){
  echo "Running preview build (non-activating)..."
  if command -v home-manager >/dev/null 2>&1; then
    home-manager build --flake "$DOTFILES#work"
    return $?
  elif command -v darwin-rebuild >/dev/null 2>&1; then
    sudo darwin-rebuild build --flake "$DOTFILES#sbfaulkner"
    return $?
  else
    echo "No home-manager or darwin-rebuild available for preview." >&2
    return 2
  fi
}

# check repo clean
repo_clean() {
  if git -C "$DOTFILES" diff --quiet --ignore-submodules -- && git -C "$DOTFILES" diff --cached --quiet; then
    return 0
  else
    return 1
  fi
}

# run reflake (choose appropriate tool)
run_reflake(){
  echo "Running reflake..."
  if command -v reflake >/dev/null 2>&1; then
    reflake
    return $?
  elif command -v home-manager >/dev/null 2>&1; then
    home-manager switch --flake "$DOTFILES#work"
    return $?
  elif command -v darwin-rebuild >/dev/null 2>&1; then
    sudo darwin-rebuild switch --flake "$DOTFILES#sbfaulkner"
    return $?
  else
    echo "No reflake command found; please ensure 'reflake' alias or home-manager/darwin-rebuild is available." >&2
    return 2
  fi
}

# decide action
if [[ $remote_changed -eq 0 && $local_changed -eq 0 ]]; then
  # No immediate changes. If age threshold exceeded, prompt to run reflake.
  if [[ $FORCE -eq 1 || $(( now_epoch - last_check_epoch )) -ge $check_age_seconds ]]; then
    # prompt the user (interactive guaranteed here)
    if ! is_tty && [[ $YES -eq 1 ]]; then
      ans="y"
    else
      printf "It\'s been %d days since last check. Run reflake now? [y/N] " $(( (now_epoch - last_check_epoch) / 86400 ))
      read -r ans || ans="n"
    fi
    if [[ "$ans" =~ ^[Yy]$ ]]; then
      if repo_clean; then
        run_reflake || exit $?
        action_performed=1
      else
        echo "Repo dirty; please stash/commit before running reflake." >&2
        exit 3
      fi
    else
      echo "Skipped."; printf "LAST_CHECK_EPOCH=%s\nLAST_HEAD=%s\nLAST_SUCCESS_EPOCH=%s\n" "$now_epoch" "$local_head" "$last_success_epoch" > "$STATE_FILE"; exit 0
    fi
  else
    # not old enough
    printf "LAST_CHECK_EPOCH=%s\nLAST_HEAD=%s\nLAST_SUCCESS_EPOCH=%s\n" "$now_epoch" "$local_head" "$last_success_epoch" > "$STATE_FILE"
    exit 0
  fi
fi

# prompt or auto behavior
action_performed=0
if [[ $remote_changed -eq 1 ]]; then
  case "$MODE" in
    prompt)
      if ! is_tty && [[ $YES -eq 1 ]]; then
        ans="y"
      else
        printf "Remote has updates (origin/%s != local). Pull & reflake? [y/N] " "$branch"
        read -r ans || ans="n"
      fi
      if [[ "$ans" =~ ^[Yy]$ ]]; then
        if repo_clean; then
          git -C "$DOTFILES" pull --ff-only origin "$branch"
          run_reflake || exit $?
          action_performed=1
        else
          echo "Repo dirty; please stash/commit before auto-pull." >&2
          exit 3
        fi
      else
        echo "Skipped."; printf "LAST_CHECK_EPOCH=%s\nLAST_HEAD=%s\nLAST_SUCCESS_EPOCH=%s\n" "$now_epoch" "$local_head" "$last_success_epoch" > "$STATE_FILE"; exit 0
      fi
      ;;
    auto-pull)
      if repo_clean; then
        git -C "$DOTFILES" pull --ff-only origin "$branch"
        run_reflake || exit $?
        action_performed=1
      else
        echo "Repo dirty; skipping auto-pull." >&2; printf "LAST_CHECK_EPOCH=%s\nLAST_HEAD=%s\nLAST_SUCCESS_EPOCH=%s\n" "$now_epoch" "$local_head" "$last_success_epoch" > "$STATE_FILE"; exit 3
      fi
      ;;
    auto)
      # in auto mode, do not pull; require manual pull but run reflake if local differs
      if repo_clean; then
        run_reflake || exit $?
        action_performed=1
      else
        echo "Repo dirty; skipping auto reflake." >&2; printf "LAST_CHECK_EPOCH=%s\nLAST_HEAD=%s\nLAST_SUCCESS_EPOCH=%s\n" "$now_epoch" "$local_head" "$last_success_epoch" > "$STATE_FILE"; exit 3
      fi
      ;;
    *)
      echo "Unknown REFLAKE_MODE: $MODE" >&2; printf "LAST_CHECK_EPOCH=%s\nLAST_HEAD=%s\nLAST_SUCCESS_EPOCH=%s\n" "$now_epoch" "$local_head" "$last_success_epoch" > "$STATE_FILE"; exit 2 ;;
  esac
elif [[ $local_changed -eq 1 ]]; then
  case "$MODE" in
    prompt)
      if ! is_tty && [[ $YES -eq 1 ]]; then
        ans="y"
      else
        printf "Local checkout changed since last reflake. Run reflake now? [y/N] "
        read -r ans || ans="n"
      fi
      if [[ "$ans" =~ ^[Yy]$ ]]; then
        run_reflake || exit $?
        action_performed=1
      else
        echo "Skipped."; printf "LAST_CHECK_EPOCH=%s\nLAST_HEAD=%s\nLAST_SUCCESS_EPOCH=%s\n" "$now_epoch" "$local_head" "$last_success_epoch" > "$STATE_FILE"; exit 0
      fi
      ;;
    auto|auto-pull)
      if repo_clean; then
        run_reflake || exit $?
        action_performed=1
      else
        echo "Repo dirty; skipping auto reflake." >&2; printf "LAST_CHECK_EPOCH=%s\nLAST_HEAD=%s\nLAST_SUCCESS_EPOCH=%s\n" "$now_epoch" "$local_head" "$last_success_epoch" > "$STATE_FILE"; exit 3
      fi
      ;;
    *) echo "Unknown REFLAKE_MODE: $MODE" >&2; printf "LAST_CHECK_EPOCH=%s\nLAST_HEAD=%s\nLAST_SUCCESS_EPOCH=%s\n" "$now_epoch" "$local_head" "$last_success_epoch" > "$STATE_FILE"; exit 2 ;;
  esac
fi

# on success, record LAST_HEAD & LAST_EPOCH
if [[ $action_performed -eq 1 ]]; then
  now_epoch=$(date +%s)
  printf "LAST_CHECK_EPOCH=%s\nLAST_HEAD=%s\nLAST_SUCCESS_EPOCH=%s\n" "$now_epoch" "$local_head" "$now_epoch" > "$STATE_FILE"
else
  # record that we checked without running reflake
  printf "LAST_CHECK_EPOCH=%s\nLAST_HEAD=%s\nLAST_SUCCESS_EPOCH=%s\n" "$now_epoch" "$local_head" "$last_success_epoch" > "$STATE_FILE"
fi

exit 0
